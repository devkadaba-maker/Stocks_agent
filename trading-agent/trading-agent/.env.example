# --- API Keys ---
IBKR_BASE_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-pro
TAVILY_API_KEY=

# --- Strategy ---
MAX_POSITIONS=10
MAX_POSITION_PCT=20
MAX_DAILY_TRADES=5
STOP_LOSS_PCT=7
ATR_MULTIPLIER=2.0
MIN_CONVICTION_SCORE=6
CLOSE_POSITIONS_EOD=false
CASH_RESERVE_PCT=15
DEPLOYMENT_CAUTION_PCT=70
# Caps the effective portfolio size the agent works with. 0 means no limit.
MAX_CAPITAL=0
# When true, the agent prints planned trades and waits for user approval
# before placing any orders.
REQUIRE_CONFIRMATION=true

# --- Screener ---
MIN_PRICE=5
MAX_PRICE=500
# Size proxy: max average daily dollar volume (price x volume).
# Mega-caps trade $1B+/day. $200M ceiling keeps small/mid-caps only.
MAX_AVG_DOLLAR_VOLUME=200000000
MIN_AVG_VOLUME=200000
SHORTLIST_SIZE=20
SCREEN_DAYS=60

# --- Schedule (ET) ---
SCREEN_TIME=09:30
CYCLE_INTERVAL_MINUTES=150
SUMMARY_TIME=15:55
