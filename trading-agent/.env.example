# --- API Keys ---
IBKR_BASE_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-pro
TAVILY_API_KEY=

# --- Strategy ---
MAX_POSITIONS=10
MAX_POSITION_PCT=20
MAX_DAILY_TRADES=5
STOP_LOSS_PCT=7
ATR_MULTIPLIER=2.0
MIN_CONVICTION_SCORE=6
CLOSE_POSITIONS_EOD=false
CASH_RESERVE_PCT=15
DEPLOYMENT_CAUTION_PCT=70
# Caps the effective portfolio size the agent works with. 0 means no limit.
MAX_CAPITAL=0
# When true, the agent prints planned trades and waits for user approval
# before placing any orders.
REQUIRE_CONFIRMATION=true

# --- Screener ---
# 200000 admits small/mid-caps; a higher floor (e.g. 5000000) restricts the
# screen to large institutional-volume names only.
MIN_PRICE=5
MAX_PRICE=500
MIN_AVG_VOLUME=200000
SHORTLIST_SIZE=20
# yfinance treats "Nd" as N trading days; 90 stays comfortably above the
# 45-bar indicator minimum.
SCREEN_DAYS=90

# --- Schedule (ET) ---
SCREEN_TIME=09:30
CYCLE_INTERVAL_MINUTES=150
SUMMARY_TIME=15:55
